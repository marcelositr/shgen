#!/bin/sh
# ==============================================================================
# Script: vgen
# Descrição: Script de automação para vgen
# Gerado por: Gemini CLI
# Data: 2026-04-04 16:10
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do VGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "vgen: %s\n" "$1"
}

error() {
    printf "vgen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    V_EXEC=""
    if command -v v >/dev/null 2>&1; then
        V_EXEC="v"
    fi

    if [ -n "$V_EXEC" ]; then
        log "Validando '$val_file' com $V_EXEC..."
        # v check ou v -check-syntax
        if "$V_EXEC" -check-syntax "$val_file" >/dev/null 2>&1; then
            log "Validação concluída: Sintaxe de '$val_file' está correta."
        else
            log "Aviso: O arquivo '$val_file' contém erros de sintaxe V."
        fi
    fi
}

usage() {
    cat <<EOF
VGen v$VERSION – Gerador de V Scripts

Uso:
  vgen <comando> [opções]

Comandos:
  init <arquivo.v>         Cria um novo arquivo V com layout base.
  add <arquivo.v> <mod>    Adiciona um módulo funcional ao arquivo.
  list                     Lista os módulos disponíveis.
  help                     Mostra esta ajuda.

Módulos disponíveis:
  os       Acesso a argumentos e sistema (import os).
  net      Boilerplate de rede (import net.http).
  time     Uso do módulo time (import time).
  file     Operações de leitura de arquivo via os.

Exemplo:
  vgen init meu_script.v
  vgen add meu_script.v os
EOF
}

# --- Templates de Módulos V ---

get_mod_base() {
    cat <<EOF
/*
 * ==============================================================================
 * Arquivo: $(basename "${file:-script.v}")
 * Descrição: [Descreva a finalidade deste script aqui]
 * Gerado por: VGen (V Script Generator)
 * Data: $(date '+%Y-%m-%d %H:%M')
 * ==============================================================================
 */

// -- MODULE_IMPORTS --

fn main() {
    println('[{PROGNAME}] Iniciando execução...')

    // Adicione sua lógica aqui
}
EOF
}

# --- Definições de Módulos V ---

# os
mod_os_imp='import os'
mod_os_code="
fn check_args() {
    args := os.args
    println(\"Argumentos: \${args}\")
}"

# net
mod_net_imp='import net.http'
mod_net_code="
fn fetch_url(url string) !string {
    resp := http.get(url)!
    return resp.body
}"

# time
mod_time_imp='import time'
mod_time_code="
fn time_example() {
    now := time.now()
    println(\"Agora: \${now}\")
}"


# file
mod_file_imp='import os'
mod_file_code='
fn read_file_example(path string) !string {
    content := os.read_file(path)!
    return content
}'

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    log "Arquivo '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'vgen init' primeiro."

    case "$mod" in
        os)   imp=$mod_os_imp   ; code=$mod_os_code ;;
        net)  imp=$mod_net_imp  ; code=$mod_net_code ;;
        time) imp=$mod_time_imp ; code=$mod_time_code ;;
        file) imp=$mod_file_imp ; code=$mod_file_code ;;
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted_imp=false
    inserted_code=false
    while IFS= read -r line; do
        if [ "$line" = "// -- MODULE_IMPORTS --" ] && [ "$inserted_imp" = false ]; then
            printf "%s\n" "$imp" >> "$tmp_edit"
            inserted_imp=true
        fi
        printf "%s\n" "$line" >> "$tmp_edit"
        if [ "$line" = "fn main() {" ] && [ "$inserted_code" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted_code=true
        fi
    done < "$file"
    
    mv "$tmp_edit" "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no VGen:\n"
    printf "  - os   : Acesso a argumentos e sistema\n"
    printf "  - net  : Boilerplate de rede\n"
    printf "  - time : Uso do módulo time\n"
    printf "  - file : Operações de leitura de arquivo\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
