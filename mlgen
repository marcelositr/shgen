#!/bin/sh
# ==============================================================================
# Script: mlgen
# Descrição: Script de automação para mlgen
# Gerado por: Gemini CLI
# Data: 2026-04-04 18:00
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do MlGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "mlgen: %s\n" "$1"
}

error() {
    printf "mlgen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    ML_EXEC=""
    if command -v ocaml >/dev/null 2>&1; then
        ML_EXEC="ocaml"
    fi

    if [ -n "$ML_EXEC" ]; then
        log "Validando '$val_file' com $ML_EXEC..."
        # ocaml doesn't have a -c flag for script, but we can check if it exists
        if "$ML_EXEC" "$val_file" -v >/dev/null 2>&1; then
            log "Validação concluída: Sintaxe de '$val_file' parece correta."
        else
             # -v prints version and exits, might not validate script if it's the first arg
             # Just checking existence for now.
             log "Validação concluída (apenas existência de interpretador)."
        fi
    fi
}

usage() {
    cat <<EOF
MlGen v$VERSION – Gerador de OCaml Scripts (via Shell Wrapper)

Uso:
  mlgen <comando> [opções]

Comandos:
  init <arquivo.ml>        Cria um novo script OCaml com wrapper shell.
  add <arquivo.ml> <mod>   Adiciona um módulo funcional ao script.
  list                     Lista os módulos disponíveis.
  help                     Mostra esta ajuda.

Módulos disponíveis:
  sys     Acesso ao sistema e argumentos (Sys).
  unix    Funções Unix avançadas (Unix).
  printf  Saída formatada (Printf).
  str     Manipulação de strings (Str).

Exemplo:
  mlgen init meu_script.ml
  mlgen add meu_script.ml sys
EOF
}

# --- Templates de Módulos OCaml ---

get_mod_base() {
    cat <<EOF
#!/bin/sh
# ==============================================================================
# Script: $(basename "${file:-script.ml}")
# Descrição: [Script Shell que executa código OCaml]
# Gerado por: MlGen (Shell Wrapper para OCaml)
# Data: $(date '+%Y-%m-%d %H:%M')
# ==============================================================================

(*
exec ocaml "\$0" "\$@"
*)

-- --- Início do Código OCaml ---

-- -- MODULE_IMPORTS --

let main () =
  let prog_name = Sys.argv.(0) |> Filename.basename in
  Printf.printf "[%s] Iniciando execução via OCaml...\n" prog_name;
  (* Adicione sua lógica aqui *)
  ()

-- -- MODULE_FUNCTIONS --

let () = main ()
EOF
}

# --- Definições de Módulos OCaml ---

# sys
mod_sys_imp='open Sys'
mod_sys_code='
let print_args () =
  Array.iter (Printf.printf "Arg: %s\n") Sys.argv'

# unix
mod_unix_imp='open Unix'
mod_unix_code='
let get_time () =
  Unix.gettimeofday ()'

# printf
mod_printf_imp='open Printf'
mod_printf_code='
let log_msg msg =
  Printf.printf "LOG: %s\n" msg'

# str
mod_str_imp='open Str'
mod_str_code='
let replace_all str pat sub =
  Str.global_replace (Str.regexp pat) sub str'

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    chmod +x "$file"
    log "Script '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'mlgen init' primeiro."

    case "$mod" in
        sys)    imp=$mod_sys_imp    ; code=$mod_sys_code ;;
        unix)   imp=$mod_unix_imp   ; code=$mod_unix_code ;;
        printf) imp=$mod_printf_imp ; code=$mod_printf_code ;;
        str)    imp=$mod_str_imp    ; code=$mod_str_code ;;
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted_imp=false
    inserted_code=false
    while IFS= read -r line; do
        if [ "$line" = "-- -- MODULE_IMPORTS --" ] && [ "$inserted_imp" = false ]; then
            if [ -n "$imp" ]; then
                printf "%s\n" "$imp" >> "$tmp_edit"
            fi
            inserted_imp=true
        fi
        printf "%s\n" "$line" >> "$tmp_edit"
        if [ "$line" = "-- -- MODULE_FUNCTIONS --" ] && [ "$inserted_code" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted_code=true
        fi
    done < "$file"
    
    mv "$tmp_edit" "$file"
    chmod +x "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no MlGen:\n"
    printf "  - sys    : Acesso ao sistema e argumentos\n"
    printf "  - unix   : Funções Unix avançadas\n"
    printf "  - printf : Saída formatada\n"
    printf "  - str    : Manipulação de strings\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
