#!/bin/sh
# ==============================================================================
# Script: hsgen
# Descrição: Script de automação para hsgen
# Gerado por: Gemini CLI
# Data: 2026-04-04 17:50
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do HsGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "hsgen: %s\n" "$1"
}

error() {
    printf "hsgen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    HS_EXEC=""
    if command -v ghc >/dev/null 2>&1; then
        HS_EXEC="ghc"
    fi

    if [ -n "$HS_EXEC" ]; then
        log "Validando '$val_file' com $HS_EXEC -fno-code..."
        if "$HS_EXEC" -fno-code "$val_file" >/dev/null 2>&1; then
            log "Validação concluída: Sintaxe de '$val_file' está correta."
        else
            log "Aviso: O arquivo '$val_file' contém erros de sintaxe Haskell."
        fi
    fi
}

usage() {
    cat <<EOF
HsGen v$VERSION – Gerador de Haskell Scripts (via Shell Wrapper)

Uso:
  hsgen <comando> [opções]

Comandos:
  init <arquivo.hs>        Cria um novo script Haskell com wrapper shell.
  add <arquivo.hs> <mod>   Adiciona um módulo funcional ao script.
  list                     Lista os módulos disponíveis.
  help                     Mostra esta ajuda.

Módulos disponíveis:
  args    Acesso a argumentos da linha de comando (System.Environment).
  io      Operações básicas de entrada/saída.
  process Execução de processos externos (System.Process).
  time    Manipulação de tempo (Data.Time).

Exemplo:
  hsgen init meu_script.hs
  hsgen add meu_script.hs args
EOF
}

# --- Templates de Módulos Haskell ---

get_mod_base() {
    cat <<EOF
#!/bin/sh
# ==============================================================================
# Script: $(basename "${file:-script.hs}")
# Descrição: [Script Shell que executa código Haskell]
# Gerado por: HsGen (Shell Wrapper para Haskell)
# Data: $(date '+%Y-%m-%d %H:%M')
# ==============================================================================

{-
exec runghc "\$0" "\$@"
-}

-- --- Início do Código Haskell ---

import System.Environment (getProgName)

-- -- MODULE_IMPORTS --

main :: IO ()
main = do
    progName <- getProgName
    putStrLn \$ "[" ++ progName ++ "] Iniciando execução via Haskell..."
    
    -- Adicione sua lógica aqui

-- -- MODULE_FUNCTIONS --
EOF
}

# --- Definições de Módulos Haskell ---

# args
mod_args_imp='import System.Environment (getArgs)'
mod_args_code='
printArgs :: IO ()
printArgs = do
    args <- getArgs
    putStrLn \$ "Argumentos: " ++ show args'

# io
mod_io_imp=''
mod_io_code='
readExample :: FilePath -> IO String
readExample = readFile'

# process
mod_process_imp='import System.Process (callCommand)'
mod_process_code='
runShell :: String -> IO ()
runShell = callCommand'

# time
mod_time_imp='import Data.Time (getCurrentTime)'
mod_time_code='
printTime :: IO ()
printTime = do
    now <- getCurrentTime
    putStrLn \$ "Agora: " ++ show now'

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    chmod +x "$file"
    log "Script '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'hsgen init' primeiro."

    case "$mod" in
        args)    imp=$mod_args_imp    ; code=$mod_args_code ;;
        io)      imp=$mod_io_imp      ; code=$mod_io_code ;;
        process) imp=$mod_process_imp ; code=$mod_process_code ;;
        time)    imp=$mod_time_imp    ; code=$mod_time_code ;;
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted_imp=false
    inserted_code=false
    while IFS= read -r line; do
        if [ "$line" = "-- -- MODULE_IMPORTS --" ] && [ "$inserted_imp" = false ]; then
            if [ -n "$imp" ]; then
                printf "%s\n" "$imp" >> "$tmp_edit"
            fi
            inserted_imp=true
        fi
        printf "%s\n" "$line" >> "$tmp_edit"
        if [ "$line" = "-- -- MODULE_FUNCTIONS --" ] && [ "$inserted_code" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted_code=true
        fi
    done < "$file"
    
    mv "$tmp_edit" "$file"
    chmod +x "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no HsGen:\n"
    printf "  - args    : Acesso a argumentos da linha de comando\n"
    printf "  - io      : Operações básicas de entrada/saída\n"
    printf "  - process : Execução de processos externos\n"
    printf "  - time    : Manipulação de tempo\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
