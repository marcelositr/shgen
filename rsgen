#!/bin/sh
# ==============================================================================
# Script: rsgen
# Descrição: Script de automação para rsgen
# Gerado por: Gemini CLI
# Data: 2026-04-04 15:40
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do RsGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "rsgen: %s\n" "$1"
}

error() {
    printf "rsgen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    RS_EXEC=""
    if command -v rustc >/dev/null 2>&1; then
        RS_EXEC="rustc"
    fi

    if [ -n "$RS_EXEC" ]; then
        log "Validando '$val_file' com $RS_EXEC..."
        # rustc --examine ou similar? rustc -Z no-codegen? 
        # rustc --emit=dep-info -o /dev/null is often used for syntax check.
        # But rustc --parse-only is not stable.
        # Let's use rustc -o /dev/null --emit=dep-info.
        if "$RS_EXEC" --emit=dep-info -o /dev/null "$val_file" >/dev/null 2>&1; then
            log "Validação concluída: Sintaxe de '$val_file' está correta."
            rm -f "$(basename "$val_file" .rs).d" # Limpa arquivo de dep-info
        else
            log "Aviso: O arquivo '$val_file' contém erros de sintaxe Rust."
        fi
    fi
}

usage() {
    cat <<EOF
RsGen v$VERSION – Gerador de Rust Scripts

Uso:
  rsgen <comando> [opções]

Comandos:
  init <arquivo.rs>         Cria um novo arquivo Rust com layout base.
  add <arquivo.rs> <mod>    Adiciona um módulo funcional ao arquivo.
  list                      Lista os módulos disponíveis.
  help                      Mostra esta ajuda.

Módulos disponíveis:
  args       Parsing básico de argumentos (std::env).
  fs         Operações de sistema de arquivos (std::fs).
  error      Boilerplate de tratamento de erros.
  test       Estrutura básica de testes unitários.

Exemplo:
  rsgen init meu_script.rs
  rsgen add meu_script.rs args
EOF
}

# --- Templates de Módulos Rust ---

get_mod_base() {
    cat <<EOF
/*
 * ==============================================================================
 * Arquivo: $(basename "${file:-script.rs}")
 * Descrição: [Descreva a finalidade deste script aqui]
 * Gerado por: RsGen (Rust Script Generator)
 * Data: $(date '+%Y-%m-%d %H:%M')
 * ==============================================================================
 */

fn main() {
    println!("[{}] Iniciando execução...", "PROGNAME");

    // Adicione sua lógica aqui
}
EOF
}

get_mod_args() {
    cat <<EOF

use std::env;
/* --- Módulo Args --- */
fn parse_args() {
    let args: Vec<String> = env::args().collect();
    println!("Argumentos: {:?}", args);
}
EOF
}

get_mod_fs() {
    cat <<EOF

use std::fs;
use std::path::Path;
/* --- Módulo FS --- */
fn check_file(path: &str) -> bool {
    Path::new(path).exists()
}
EOF
}

get_mod_error() {
    cat <<EOF

use std::error::Error;
/* --- Módulo Error --- */
type Result<T> = std::result::Result<T, Box<dyn Error>>;

fn run() -> Result<()> {
    // Lógica que pode falhar
    Ok(())
}
EOF
}

get_mod_test() {
    cat <<EOF

#[cfg(test)]
mod tests {
    #[test]
    fn it_works() {
        assert_eq!(2 + 2, 4);
    }
}
EOF
}

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    log "Arquivo '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'rsgen init' primeiro."

    case "$mod" in
        args)  code=$(get_mod_args)  ; anchor="fn main()" ;;
        fs)    code=$(get_mod_fs)    ; anchor="fn main()" ;;
        error) code=$(get_mod_error) ; anchor="fn main()" ;;
        test)  code=$(get_mod_test)  ; anchor="" ;; # Final do arquivo
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted=false
    while IFS= read -r line; do
        if [ -n "$anchor" ] && [ "$line" = "$anchor" ] && [ "$inserted" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted=true
        fi
        printf "%s\n" "$line" >> "$tmp_edit"
    done < "$file"
    
    if [ "$inserted" = false ]; then
        printf "%s\n" "$code" >> "$tmp_edit"
    fi

    mv "$tmp_edit" "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no RsGen:\n"
    printf "  - args  : Parsing básico de argumentos (std::env)\n"
    printf "  - fs    : Operações de sistema de arquivos (std::fs)\n"
    printf "  - error : Boilerplate de tratamento de erros\n"
    printf "  - test  : Estrutura básica de testes unitários\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
