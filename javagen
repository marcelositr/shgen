#!/bin/sh
# ==============================================================================
# Script: javagen
# Descrição: Script de automação para javagen
# Gerado por: Gemini CLI
# Data: 2026-04-04 16:20
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do JavaGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "javagen: %s\n" "$1"
}

error() {
    printf "javagen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    JAVA_EXEC=""
    if command -v javac >/dev/null 2>&1; then
        JAVA_EXEC="javac"
    fi

    if [ -n "$JAVA_EXEC" ]; then
        log "Validando '$val_file' com $JAVA_EXEC..."
        # javac -Xlint ou apenas javac
        if "$JAVA_EXEC" "$val_file" >/dev/null 2>&1; then
            log "Validação concluída: Sintaxe de '$val_file' está correta."
            # Remove o arquivo .class gerado
            class_file=$(echo "$val_file" | sed 's/\.java$/.class/')
            rm -f "$class_file"
        else
            log "Aviso: O arquivo '$val_file' contém erros de sintaxe Java."
        fi
    fi
}

usage() {
    cat <<EOF
JavaGen v$VERSION – Gerador de Java Scripts

Uso:
  javagen <comando> [opções]

Comandos:
  init <arquivo.java>        Cria um novo arquivo Java com layout base.
  add <arquivo.java> <mod>   Adiciona um módulo funcional ao arquivo.
  list                       Lista os módulos disponíveis.
  help                       Mostra esta ajuda.

Módulos disponíveis:
  io       Operações de entrada/saída (java.io.*).
  util     Coleções e utilitários (java.util.*).
  net      Rede e HTTP (java.net.*).
  logging  Logs padrão (java.util.logging.*).

Exemplo:
  javagen init MeuScript.java
  javagen add MeuScript.java io
EOF
}

# --- Templates de Módulos Java ---

get_mod_base() {
    class_name=$(basename "${file:-Script.java}" .java)
    cat <<EOF
/*
 * ==============================================================================
 * Arquivo: $(basename "${file:-Script.java}")
 * Descrição: [Descreva a finalidade deste script aqui]
 * Gerado por: JavaGen (Java Script Generator)
 * Data: $(date '+%Y-%m-%d %H:%M')
 * ==============================================================================
 */

// -- MODULE_IMPORTS --

public class ${class_name} {

    public static void main(String[] args) {
        System.out.println("[${class_name}] Iniciando execução...");

        // Adicione sua lógica aqui
    }

    // -- MODULE_METHODS --
}
EOF
}

# --- Definições de Módulos Java ---

# io
mod_io_imp='import java.io.*;'
mod_io_code='
    public static void checkFile(String path) {
        File file = new File(path);
        System.out.println("Arquivo existe: " + file.exists());
    }'

# util
mod_util_imp='import java.util.*;'
mod_util_code='
    public static void listExample() {
        List<String> items = new ArrayList<>();
        items.add("Item 1");
        System.out.println("Itens: " + items);
    }'

# net
mod_net_imp='import java.net.*;'
mod_net_code='
    public static void netExample() throws Exception {
        URL url = new URL("https://api.github.com");
        System.out.println("Host: " + url.getHost());
    }'

# logging
mod_logging_imp='import java.util.logging.*;'
mod_logging_code='
    private static final Logger LOGGER = Logger.getLogger(java.lang.invoke.MethodHandles.lookup().lookupClass().getName());
    public static void logExample() {
        LOGGER.info("Mensagem de log.");
    }'

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    log "Arquivo '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'javagen init' primeiro."

    case "$mod" in
        io)      imp=$mod_io_imp      ; code=$mod_io_code ;;
        util)    imp=$mod_util_imp    ; code=$mod_util_code ;;
        net)     imp=$mod_net_imp     ; code=$mod_net_code ;;
        logging) imp=$mod_logging_imp ; code=$mod_logging_code ;;
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted_imp=false
    inserted_code=false
    while IFS= read -r line; do
        if [ "$line" = "// -- MODULE_IMPORTS --" ] && [ "$inserted_imp" = false ]; then
            printf "%s\n" "$imp" >> "$tmp_edit"
            inserted_imp=true
        fi
        printf "%s\n" "$line" >> "$tmp_edit"
        if [ "$line" = "    // -- MODULE_METHODS --" ] && [ "$inserted_code" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted_code=true
        fi
    done < "$file"
    
    mv "$tmp_edit" "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no JavaGen:\n"
    printf "  - io      : Operações de entrada/saída (java.io.*)\n"
    printf "  - util    : Coleções e utilitários (java.util.*)\n"
    printf "  - net     : Rede e HTTP (java.net.*)\n"
    printf "  - logging : Logs padrão (java.util.logging.*)\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
