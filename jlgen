#!/bin/sh
# ==============================================================================
# Script: jlgen
# Descrição: Script de automação para jlgen
# Gerado por: Gemini CLI
# Data: 2026-04-04 17:20
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do JlGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "jlgen: %s\n" "$1"
}

error() {
    printf "jlgen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    JL_EXEC=""
    if command -v julia >/dev/null 2>&1; then
        JL_EXEC="julia"
    fi

    if [ -n "$JL_EXEC" ]; then
        log "Validando '$val_file' com $JL_EXEC..."
        # Julia não tem um flag -c simples. Vamos apenas verificar se o arquivo é lido sem erro fatal imediato
        if "$JL_EXEC" -e "include(\"$val_file\")" >/dev/null 2>&1; then
            log "Validação básica concluída: '$val_file' parece correto."
        else
            log "Aviso: O arquivo '$val_file' pode conter erros de sintaxe Julia ou falha na execução."
        fi
    fi
}

usage() {
    cat <<EOF
JlGen v$VERSION – Gerador de Julia Scripts (via Shell Wrapper)

Uso:
  jlgen <comando> [opções]

Comandos:
  init <arquivo.jl>        Cria um novo script Julia com wrapper shell.
  add <arquivo.jl> <mod>   Adiciona um módulo funcional ao script.
  list                     Lista os módulos disponíveis.
  help                     Mostra esta ajuda.

Módulos disponíveis:
  logging   Configuração de log padrão (using Logging).
  args      Acesso a argumentos da linha de comando (ARGS).
  json      Manipulação de JSON (using JSON).
  stats     Uso de Statistics (using Statistics).

Exemplo:
  jlgen init meu_script.jl
  jlgen add meu_script.jl args
EOF
}

# --- Templates de Módulos Julia ---

get_mod_base() {
    cat <<EOF
#!/bin/sh
# ==============================================================================
# Script: $(basename "${file:-script.jl}")
# Descrição: [Script Shell que executa código Julia]
# Gerado por: JlGen (Shell Wrapper para Julia)
# Data: $(date '+%Y-%m-%d %H:%M')
# ==============================================================================

""":"
exec julia "\$0" "\$@"
"""

# --- Início do Código Julia ---

# --- Constantes Globais ---
const PROGNAME = basename(PROGRAM_FILE)

# --- Funções ---

function main()
    println("[\$(PROGNAME)] Iniciando execução via Julia...")
    # Adicione sua lógica aqui
end

# --- Execução Principal ---
if abspath(PROGRAM_FILE) == @__FILE__
    main()
end
EOF
}

get_mod_logging() {
    cat <<EOF

using Logging
# --- Módulo Logging ---
logger = ConsoleLogger(stdout, Logging.Info)
global_logger(logger)
EOF
}

get_mod_args() {
    cat <<EOF

# --- Módulo Args ---
function print_args()
    println("Argumentos: \$(ARGS)")
end
EOF
}

get_mod_json() {
    cat <<EOF

using JSON
# --- Módulo JSON ---
# data = JSON.parse(json_string)
EOF
}

get_mod_stats() {
    cat <<EOF

using Statistics
# --- Módulo Statistics ---
# m = mean([1, 2, 3])
EOF
}

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    chmod +x "$file"
    log "Script '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'jlgen init' primeiro."

    case "$mod" in
        logging) code=$(get_mod_logging) ; anchor="# --- Início do Código Julia ---" ;;
        args)    code=$(get_mod_args)    ; anchor="# --- Início do Código Julia ---" ;;
        json)    code=$(get_mod_json)    ; anchor="# --- Início do Código Julia ---" ;;
        stats)   code=$(get_mod_stats)   ; anchor="# --- Início do Código Julia ---" ;;
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted=false
    while IFS= read -r line; do
        printf "%s\n" "$line" >> "$tmp_edit"
        if [ "$line" = "$anchor" ] && [ "$inserted" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted=true
        fi
    done < "$file"
    
    mv "$tmp_edit" "$file"
    chmod +x "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no JlGen:\n"
    printf "  - logging : Configuração de log padrão\n"
    printf "  - args    : Acesso a argumentos da linha de comando\n"
    printf "  - json    : Manipulação de JSON\n"
    printf "  - stats   : Uso do módulo Statistics\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
