#!/bin/sh
# ==============================================================================
# Script: scalagen
# Descrição: Script de automação para scalagen
# Gerado por: Gemini CLI
# Data: 2026-04-04 16:40
# ==============================================================================

set -eu

# IFS seguro (quebra de linha apenas)
IFS='
'

# Versão do ScalaGen
VERSION="1.0.0"

# --- Funções Auxiliares do Gerador ---

log() {
    printf "scalagen: %s\n" "$1"
}

error() {
    printf "scalagen erro: %s\n" "$1" >&2
    exit 1
}

validate_script() {
    val_file="$1"
    SCALA_EXEC=""
    if command -v scalac >/dev/null 2>&1; then
        SCALA_EXEC="scalac"
    fi

    if [ -n "$SCALA_EXEC" ]; then
        log "Validando '$val_file' com $SCALA_EXEC..."
        if "$SCALA_EXEC" "$val_file" -d /tmp >/dev/null 2>&1; then
            log "Validação concluída: Sintaxe de '$val_file' está correta."
        else
            log "Aviso: O arquivo '$val_file' contém erros de sintaxe Scala."
        fi
    fi
}

usage() {
    cat <<EOF
ScalaGen v$VERSION – Gerador de Scala Scripts

Uso:
  scalagen <comando> [opções]

Comandos:
  init <arquivo.scala>      Cria um novo arquivo Scala com layout base.
  add <arquivo.scala> <mod> Adiciona um módulo funcional ao arquivo.
  list                      Lista os módulos disponíveis.
  help                      Mostra esta ajuda.

Módulos disponíveis:
  io       Operações de entrada/saída (java.io.*).
  util     Coleções e utilitários Scala.
  net      Rede e HTTP (java.net.*).
  app      Uso da trait App para execução simplificada.

Exemplo:
  scalagen init meu_script.scala
  scalagen add meu_script.scala io
EOF
}

# --- Templates de Módulos Scala ---

get_mod_base() {
    cat <<EOF
/*
 * ==============================================================================
 * Arquivo: $(basename "${file:-script.scala}")
 * Descrição: [Descreva a finalidade deste script aqui]
 * Gerado por: ScalaGen (Scala Script Generator)
 * Data: $(date '+%Y-%m-%d %H:%M')
 * ==============================================================================
 */

// -- MODULE_IMPORTS --

object Main {
  def main(args: Array<String>): Unit = {
    println("[PROGNAME] Iniciando execução...")

    // Adicione sua lógica aqui
  }

  // -- MODULE_METHODS --
}
EOF
}

# --- Definições de Módulos Scala ---

# io
mod_io_imp='import java.io.File'
mod_io_code="
  def checkFile(path: String): Unit = {
    val file = new File(path)
    println(s\"Arquivo existe: \${file.exists()}\")
  }"

# util
mod_util_imp='import scala.collection.mutable'
mod_util_code="
  def listExample(): Unit = {
    val items = List(\"Item 1\", \"Item 2\")
    println(s\"Itens: \$items\")
  }"

# net
mod_net_imp='import java.net.URL'
mod_net_code="
  def netExample(urlStr: String): Unit = {
    val url = new URL(urlStr)
    println(s\"Host: \${url.getHost}\")
  }"


# app
mod_app_imp=''
mod_app_code='
/* Para usar App trait, substitua o Main object por:
object MyApp extends App {
  println("Olá do Scala via App trait!")
}
*/'

# --- Lógica de Comandos ---

cmd_init() {
    [ $# -eq 1 ] || usage
    file="$1"
    [ -f "$file" ] && error "Arquivo '$file' já existe."
    get_mod_base > "$file"
    log "Arquivo '$file' inicializado com sucesso."
    validate_script "$file"
}

cmd_add() {
    [ $# -eq 2 ] || usage
    file="$1"
    mod="$2"
    [ -f "$file" ] || error "Arquivo '$file' não encontrado. Use 'scalagen init' primeiro."

    case "$mod" in
        io)   imp=$mod_io_imp   ; code=$mod_io_code ;;
        util) imp=$mod_util_imp ; code=$mod_util_code ;;
        net)  imp=$mod_net_imp  ; code=$mod_net_code ;;
        app)  imp=$mod_app_imp  ; code=$mod_app_code ;;
        *) error "Módulo '$mod' não reconhecido." ;;
    esac

    tmp_edit=$(mktemp)
    trap 'rm -f "$tmp_edit"' EXIT
    
    inserted_imp=false
    inserted_code=false
    while IFS= read -r line; do
        if [ "$line" = "// -- MODULE_IMPORTS --" ] && [ "$inserted_imp" = false ]; then
            if [ -n "$imp" ]; then
                printf "%s\n" "$imp" >> "$tmp_edit"
            fi
            inserted_imp=true
        fi
        printf "%s\n" "$line" >> "$tmp_edit"
        if [ "$line" = "  // -- MODULE_METHODS --" ] && [ "$inserted_code" = false ]; then
            printf "%s\n" "$code" >> "$tmp_edit"
            inserted_code=true
        fi
    done < "$file"
    
    mv "$tmp_edit" "$file"
    trap - EXIT
    log "Módulo '$mod' adicionado a '$file'."
    validate_script "$file"
}

cmd_list() {
    printf "Módulos disponíveis no ScalaGen:\n"
    printf "  - io   : Operações de entrada/saída (java.io.File)\n"
    printf "  - util : Coleções e utilitários Scala\n"
    printf "  - net  : Rede e HTTP (java.net.URL)\n"
    printf "  - app  : Uso da trait App para execução simplificada\n"
}

# --- Ponto de Entrada ---

[ $# -lt 1 ] && { usage; exit 0; }

command="$1"
shift

case "$command" in
    init) cmd_init "$@" ;;
    add)  cmd_add "$@" ;;
    list) cmd_list ;;
    help) usage ;;
    *)    error "Comando desconhecido: $command" ;;
esac
